{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile information and delivery preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "addresses": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "address": { "type": "string" }
            }
          }
        },
        "selectedAddressIndex": { "type": "number" },
        "phone": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Order": {
      "title": "Order",
      "description": "Food delivery order information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "restaurantId": { "type": "string" },
        "restaurantName": { "type": "string" },
        "total": { "type": "number" },
        "status": {
          "type": "string",
          "enum": ["pending", "preparing", "on-the-way", "delivered", "cancelled"]
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "deliveryAddress": { "type": "string" },
        "customerName": { "type": "string" }
      },
      "required": ["userId", "restaurantId", "total", "status", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "Store users profile and settings"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Store all food orders"
    }
  }
}
